{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch(domain:overpass-api.de)",
      "WebFetch(domain:services.arcgis.com)",
      "WebFetch(domain:api.mapbox.com)",
      "Bash(python3 data/pois/fetch_pois.py*)",
      "Bash(python3 data/refresh.py*)",
      "Bash(python3 data/process.py*)",
      "Bash(npm install*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run preview*)",
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm run e2e*)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "overpass-api.de",
        "services.arcgis.com",
        "api.mapbox.com"
      ]
    }
  }
}
